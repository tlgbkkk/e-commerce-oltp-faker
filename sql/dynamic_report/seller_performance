CREATE OR REPLACE FUNCTION report_seller_performance(
    p_start_date TIMESTAMP,
    p_end_date TIMESTAMP,
    p_category_id INT DEFAULT NULL,
    p_brand_id INT DEFAULT NULL
) RETURNS TABLE (
    seller_id INT,
    seller_name VARCHAR,
    total_orders BIGINT,
    total_quantity BIGINT,
    total_revenue NUMERIC
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        s.seller_id,
        s.seller_name,
        COUNT(DISTINCT o.order_id) AS total_orders,
        SUM(oi.quantity) AS total_quantity,
        SUM(oi.subtotal) AS total_revenue
    FROM "order" o
    JOIN seller s ON o.seller_id = s.seller_id
    JOIN order_item oi ON o.order_id = oi.order_id
    JOIN product p ON oi.product_id = p.product_id
    WHERE o.order_date >= p_start_date AND o.order_date <= p_end_date
      AND (p_category_id IS NULL OR p.category_id = p_category_id)
      AND (p_brand_id IS NULL OR p.brand_id = p_brand_id)
    GROUP BY s.seller_id, s.seller_name
    ORDER BY total_revenue DESC;
END;
$$ LANGUAGE plpgsql;

SELECT * FROM report_seller_performance('2025-08-01', '2025-10-31');